HOST=0.0.0.0
NODE_ENV=production
# Replace before build/deploy. Placeholder domains are rejected by env checks.
SITE_URL=https://your-domain.com

# Supabase persistence. Required for production; leave empty only for local file-mode development.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STATE_TABLE=site_state
SHIYI_STATE_ID=default

# Admin dashboard access token.
ADMIN_TOKEN=change-this-admin-token
