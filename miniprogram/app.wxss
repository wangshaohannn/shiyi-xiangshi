page {
  --paper: #f2eee4;
  --ivory: #fffaf0;
  --ink: #18211d;
  --muted: #657169;
  --gold: #ad8751;
  --amber: #d8b56f;
  --moss: #4f6257;
  --jade: #7d9585;
  --cinnabar: #9f4635;
  --line: rgba(24, 33, 29, 0.13);
  --serif: "Songti SC", "STSong", "SimSun", serif;
  min-height: 100%;
  background: #f2eee4;
  color: #18211d;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
}

view,
text,
image,
button,
input,
textarea,
slider {
  box-sizing: border-box;
}

button {
  margin: 0;
  border-radius: 0;
  line-height: 1.3;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 120rpx;
  padding-bottom: 120rpx;
  background: #f2eee4;
}

.section {
  margin-top: 32rpx;
}

.eyebrow {
  color: #ad8751;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.title {
  margin-top: 12rpx;
  color: #18211d;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.16;
}

.subtitle {
  margin-top: 16rpx;
  color: #657169;
  font-size: 27rpx;
  line-height: 1.72;
}

.card,
.soft-panel {
  overflow: hidden;
  border: 1rpx solid rgba(24, 33, 29, 0.13);
  border-radius: 16rpx;
  background: #fffaf0;
  box-shadow: 0 12rpx 34rpx rgba(24, 33, 29, 0.08);
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 40rpx;
}

.section-head-main {
  min-width: 0;
}

.gold-rule {
  width: 180rpx;
  height: 1rpx;
  margin-top: 22rpx;
  background: rgba(173, 135, 81, 0.72);
}

.mini-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.mini-meta text {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 16rpx;
  border: 1rpx solid rgba(24, 33, 29, 0.1);
  border-radius: 999rpx;
  color: #4f6257;
  background: #fffaf0;
  font-size: 21rpx;
  font-weight: 800;
}

.row {
  display: flex;
  align-items: center;
}

.space-between {
  justify-content: space-between;
}

.muted {
  color: #657169;
}

.price {
  color: #9f4635;
  font-size: 32rpx;
  font-weight: 800;
}

.primary-button,
.ghost-button,
.text-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  padding: 0 28rpx;
  border-radius: 10rpx;
  font-size: 27rpx;
  font-weight: 800;
}

.primary-button {
  background: #18211d;
  color: #fffaf0;
}

.ghost-button {
  border: 1rpx solid rgba(24, 33, 29, 0.13);
  background: #fffaf0;
  color: #18211d;
}

.text-button {
  min-height: 64rpx;
  padding: 0;
  background: transparent;
  color: #9f4635;
}

.input,
.textarea {
  width: 100%;
  border: 1rpx solid rgba(24, 33, 29, 0.13);
  border-radius: 10rpx;
  background: #fffaf0;
  color: #18211d;
  font-size: 28rpx;
}

.input {
  height: 84rpx;
  padding: 0 24rpx;
}

.textarea {
  min-height: 160rpx;
  padding: 22rpx 24rpx;
  line-height: 1.6;
}

.field {
  margin-top: 22rpx;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  color: #354038;
  font-size: 24rpx;
  font-weight: 800;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 54rpx;
  padding: 0 20rpx;
  border: 1rpx solid rgba(24, 33, 29, 0.13);
  border-radius: 999rpx;
  background: #fffaf0;
  color: #4f6257;
  font-size: 23rpx;
  font-weight: 800;
}

.empty {
  padding: 48rpx 28rpx;
  text-align: center;
  color: #657169;
  line-height: 1.7;
}
