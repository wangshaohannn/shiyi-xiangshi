.hero {
  position: relative;
  min-height: 620rpx;
  overflow: hidden;
  border-radius: 22rpx;
  background: #111814;
  box-shadow: 0 24rpx 60rpx rgba(17, 24, 20, 0.2);
}

.hero-image,
.hero-shade {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.hero-image {
  opacity: 0.72;
}

.hero-shade {
  background: rgba(10, 15, 12, 0.56);
}

.hero-content {
  position: relative;
  z-index: 2;
  display: flex;
  min-height: 620rpx;
  flex-direction: column;
  justify-content: flex-end;
  padding: 44rpx 32rpx;
}

.hero-kicker {
  color: #d8b56f;
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 3rpx;
}

.hero-title {
  margin-top: 16rpx;
  color: #fffaf0;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 76rpx;
  font-weight: 700;
  line-height: 1.08;
}

.hero-copy {
  width: 100%;
  margin-top: 18rpx;
  color: rgba(255, 250, 240, 0.88);
  font-size: 28rpx;
  line-height: 1.72;
}

.hero-proof {
  display: flex;
  flex-wrap: wrap;
  width: 100%;
  margin-top: 26rpx;
  border-top: 1rpx solid rgba(255, 250, 240, 0.22);
  border-bottom: 1rpx solid rgba(255, 250, 240, 0.22);
}

.hero-proof text {
  padding: 14rpx 18rpx;
  color: rgba(255, 250, 240, 0.82);
  font-size: 22rpx;
  font-weight: 800;
}

.hero-proof text + text {
  border-left: 1rpx solid rgba(255, 250, 240, 0.16);
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 32rpx;
}

.hero-actions button {
  flex: 1 1 230rpx;
  min-width: 0;
}

.ghost-light-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  padding: 0 28rpx;
  border: 1rpx solid rgba(255, 250, 240, 0.32);
  border-radius: 8rpx;
  background: rgba(255, 250, 240, 0.08);
  color: #fffaf0;
  font-size: 27rpx;
  font-weight: 700;
}

.small-title {
  font-size: 40rpx;
}

.quick-grid,
.services {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.quick-entry,
.service {
  flex: 1 1 300rpx;
  min-height: 156rpx;
  padding: 22rpx 18rpx;
  text-align: left;
}

.quick-index {
  color: #ad8751;
  font-size: 22rpx;
  font-weight: 900;
}

.quick-title {
  margin-top: 20rpx;
  color: #18211d;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 34rpx;
  font-weight: 700;
}

.quick-copy,
.service-text,
.feature-note {
  margin-top: 8rpx;
  color: #657169;
  font-size: 22rpx;
}

.product-scroll {
  width: 100%;
  margin-top: 22rpx;
  white-space: nowrap;
}

.product-track {
  display: inline-flex;
  gap: 22rpx;
  padding-right: 28rpx;
}

.feature-card {
  width: 400rpx;
  overflow: hidden;
  white-space: normal;
  border-radius: 18rpx;
}

.feature-image {
  width: 100%;
  height: 300rpx;
  display: block;
}

.feature-body {
  padding: 22rpx;
}

.feature-name {
  margin-top: 18rpx;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 32rpx;
  font-weight: 800;
}

.service-title {
  color: #18211d;
  font-size: 27rpx;
  font-weight: 800;
}

.maker-panel {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-end;
  justify-content: space-between;
  gap: 22rpx;
  padding: 34rpx;
}

.maker-panel > view {
  min-width: 0;
  flex: 1 1 360rpx;
}

.maker-panel .primary-button {
  flex: 1 1 220rpx;
}

.notes {
  padding: 28rpx;
}

.note {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(24, 33, 29, 0.1);
  color: #354038;
  line-height: 1.65;
}
