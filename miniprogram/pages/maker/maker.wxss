.maker-hero {
  position: relative;
  overflow: hidden;
  padding: 34rpx 28rpx;
  background: #18211d;
}

.maker-hero::after {
  position: absolute;
  right: -120rpx;
  top: -140rpx;
  width: 340rpx;
  height: 340rpx;
  border: 1rpx solid rgba(216, 181, 111, 0.22);
  border-radius: 999rpx;
  content: "";
}

.maker-hero .title {
  color: #fffaf0;
}

.maker-hero .subtitle {
  color: rgba(255, 250, 240, 0.72);
}

.formula-name {
  margin-top: 34rpx;
  color: #d8b56f;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 62rpx;
  font-weight: 600;
}

.formula-copy {
  margin-top: 14rpx;
  color: rgba(255, 250, 240, 0.82);
  font-size: 27rpx;
  line-height: 1.68;
}

.scent-orbit {
  position: relative;
  width: 320rpx;
  height: 320rpx;
  margin: 34rpx auto 0;
}

.orbit-core,
.orbit-dot {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-weight: 800;
}

.orbit-core {
  left: 50%;
  top: 50%;
  width: 112rpx;
  height: 112rpx;
  margin: -56rpx 0 0 -56rpx;
  border: 1rpx solid rgba(216, 181, 111, 0.5);
  background: rgba(255, 250, 240, 0.1);
  color: #d8b56f;
  font-size: 42rpx;
}

.orbit-line {
  position: absolute;
  left: 42rpx;
  right: 42rpx;
  top: 42rpx;
  bottom: 42rpx;
  border: 1rpx solid rgba(255, 250, 240, 0.16);
  border-radius: 999rpx;
}

.orbit-dot {
  width: 68rpx;
  height: 68rpx;
  background: rgba(255, 250, 240, 0.12);
  color: rgba(255, 250, 240, 0.84);
  font-size: 28rpx;
}

.orbit-dot.fresh {
  left: 50%;
  top: 6rpx;
  margin-left: -34rpx;
}

.orbit-dot.wood {
  right: 8rpx;
  top: 50%;
  margin-top: -34rpx;
}

.orbit-dot.warm {
  left: 50%;
  bottom: 6rpx;
  margin-left: -34rpx;
}

.orbit-dot.sweet {
  left: 8rpx;
  top: 50%;
  margin-top: -34rpx;
}

.ratio-grid,
.preset-row,
.ingredient-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 28rpx;
}

.ratio {
  flex: 1 1 240rpx;
  padding: 18rpx 8rpx;
  border: 1rpx solid rgba(255, 250, 240, 0.14);
  border-radius: 10rpx;
  background: rgba(255, 250, 240, 0.08);
  text-align: center;
}

.ratio-value {
  color: #fffaf0;
  font-size: 30rpx;
  font-weight: 900;
}

.ratio-name {
  margin-top: 8rpx;
  color: rgba(255, 250, 240, 0.66);
  font-size: 22rpx;
}

.preset {
  min-height: 64rpx;
  padding: 0 26rpx;
  border: 1rpx solid rgba(24, 33, 29, 0.13);
  border-radius: 999rpx;
  background: #fffaf0;
  color: #4f6257;
  font-size: 25rpx;
  font-weight: 800;
}

.preset.reset {
  color: #9f4635;
}

.ingredient {
  width: 100%;
  padding: 26rpx 24rpx 12rpx;
}

.ingredient-name {
  font-size: 30rpx;
  font-weight: 900;
}

.ingredient-note {
  margin-top: 8rpx;
  color: #657169;
  font-size: 23rpx;
}

.ingredient-value {
  display: flex;
  width: 58rpx;
  height: 58rpx;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #18211d;
  color: #fffaf0;
  font-weight: 900;
}

.save {
  width: 100%;
  margin-top: 30rpx;
}
