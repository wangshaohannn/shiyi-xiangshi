.profile-card {
  padding: 34rpx 28rpx;
  background: #18211d;
}

.profile-card .title {
  color: #fffaf0;
}

.profile-card .subtitle {
  color: rgba(255, 250, 240, 0.72);
}

.profile-ledger {
  display: flex;
  gap: 10rpx;
  margin-top: 28rpx;
}

.profile-ledger view {
  min-width: 0;
  flex: 1;
  padding: 16rpx 8rpx;
  border: 1rpx solid rgba(255, 250, 240, 0.14);
  border-radius: 12rpx;
  background: rgba(255, 250, 240, 0.08);
  text-align: center;
}

.profile-ledger text {
  display: block;
}

.profile-ledger text:first-child {
  color: rgba(255, 250, 240, 0.62);
  font-size: 22rpx;
  font-weight: 800;
}

.profile-ledger text:last-child {
  margin-top: 8rpx;
  color: #d8b56f;
  font-size: 34rpx;
  font-weight: 900;
}

.contact-list {
  margin-top: 28rpx;
  border-top: 1rpx solid rgba(255, 250, 240, 0.16);
}

.contact-row {
  display: flex;
  gap: 18rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(255, 250, 240, 0.12);
  color: rgba(255, 250, 240, 0.82);
  font-size: 25rpx;
  line-height: 1.55;
}

.contact-row text:first-child {
  width: 120rpx;
  color: rgba(255, 250, 240, 0.58);
  font-weight: 700;
}

.contact-row text:last-child {
  min-width: 0;
  flex: 1;
  overflow-wrap: anywhere;
}

.profile-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 28rpx;
}

.profile-actions .primary-button,
.profile-actions .ghost-button {
  width: 100%;
  min-width: 0;
  padding: 0 12rpx;
}

.profile-actions .primary-button {
  background: #fffaf0;
  color: #18211d;
  box-shadow: none;
}

.profile-actions .ghost-button {
  border-color: rgba(255, 250, 240, 0.22);
  background: rgba(255, 250, 240, 0.08);
  color: #fffaf0;
}

.record-section {
  padding: 30rpx;
}

.record-section .text-button {
  width: auto;
  min-width: 0;
  padding: 0 8rpx;
}

.record-title {
  margin-top: 6rpx;
  font-size: 34rpx;
  font-weight: 900;
}

.record {
  padding: 22rpx 0;
  border-top: 1rpx solid rgba(24, 33, 29, 0.1);
}

.record-name {
  color: #18211d;
  font-weight: 900;
}

.record-status {
  color: #9f4635;
  font-size: 23rpx;
  font-weight: 800;
}

.record-copy {
  margin-top: 8rpx;
  color: #657169;
  font-size: 24rpx;
  line-height: 1.55;
}

.formula-name {
  color: #18211d;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 34rpx;
  font-weight: 700;
}
