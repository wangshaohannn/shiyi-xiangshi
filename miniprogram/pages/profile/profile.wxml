<view class="page profile-page">
  <view class="profile-card card">
    <view class="eyebrow">CONTACT</view>
    <view class="title">到店与咨询</view>
    <view class="subtitle">复制微信号后在微信内搜索添加，沟通香品、课程、团建或礼赠定制。</view>
    <view class="profile-ledger">
      <view>
        <text>咨询单</text>
        <text>{{orders.length}}</text>
      </view>
      <view>
        <text>预约</text>
        <text>{{bookings.length}}</text>
      </view>
      <view>
        <text>香方</text>
        <text>{{formulas.length}}</text>
      </view>
    </view>
    <view class="contact-list">
      <view class="contact-row">
        <text>官方微信</text>
        <text>{{contact.wechat}}</text>
      </view>
      <view class="contact-row">
        <text>城市</text>
        <text>{{contact.city}}</text>
      </view>
      <view class="contact-row">
        <text>地址</text>
        <text>{{contact.address}}</text>
      </view>
      <view class="contact-row">
        <text>合作</text>
        <text>{{contact.collaboration}}</text>
      </view>
    </view>
    <view class="profile-actions">
      <button class="primary-button" bindtap="copyWechat">复制微信</button>
      <button class="ghost-button" bindtap="callStore">联系门店</button>
    </view>
  </view>

  <view class="section card record-section">
    <view class="row space-between">
      <view>
        <view class="eyebrow">ORDERS</view>
        <view class="record-title">咨询单</view>
      </view>
      <button class="text-button" bindtap="clearRecords">清空</button>
    </view>
    <view class="empty" wx:if="{{!orders.length}}">暂无咨询单。</view>
    <view class="record" wx:for="{{orders}}" wx:key="id">
      <view class="row space-between">
        <text class="record-name">¥{{item.total}} · {{item.pickup}}</text>
        <text class="record-status">{{item.status}}</text>
      </view>
      <view class="record-copy">{{item.buyerName}} · {{item.buyerPhone}}</view>
      <view class="record-copy" wx:for="{{item.items}}" wx:key="id">{{item.name}} x {{item.count}}</view>
    </view>
  </view>

  <view class="section card record-section">
    <view class="eyebrow">BOOKINGS</view>
    <view class="record-title">预约记录</view>
    <view class="empty" wx:if="{{!bookings.length}}">暂无预约记录。</view>
    <view class="record" wx:for="{{bookings}}" wx:key="id">
      <view class="row space-between">
        <text class="record-name">{{item.service}}</text>
        <text class="record-status">{{item.status}}</text>
      </view>
      <view class="record-copy">{{item.date}} {{item.time}} · {{item.people}}</view>
      <view class="record-copy">{{item.name}} · {{item.phone}}</view>
    </view>
  </view>

  <view class="section card record-section">
    <view class="eyebrow">FORMULAS</view>
    <view class="record-title">我的香方</view>
    <view class="empty" wx:if="{{!formulas.length}}">暂无保存香方。</view>
    <view class="record" wx:for="{{formulas}}" wx:key="id">
      <view class="row space-between">
        <text class="formula-name">{{item.name}}</text>
        <text class="record-status">已保存</text>
      </view>
      <view class="record-copy">{{item.suggestion}}</view>
    </view>
  </view>
</view>
