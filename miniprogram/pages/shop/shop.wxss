.shop-head {
  padding: 18rpx 4rpx 8rpx;
}

.shop-summary,
.selected-proof {
  display: flex;
  flex-wrap: wrap;
  margin-top: 26rpx;
  border-top: 1rpx solid rgba(24, 33, 29, 0.12);
  border-bottom: 1rpx solid rgba(24, 33, 29, 0.12);
}

.shop-summary text,
.selected-proof text {
  padding: 14rpx 18rpx;
  color: #4f6257;
  font-size: 22rpx;
  font-weight: 900;
}

.category-scroll {
  width: 100%;
  margin-top: 24rpx;
  white-space: nowrap;
}

.category-track {
  display: inline-flex;
  gap: 14rpx;
  padding-right: 28rpx;
}

.category-pill {
  min-height: 64rpx;
  padding: 0 26rpx;
  border: 1rpx solid rgba(24, 33, 29, 0.13);
  border-radius: 999rpx;
  background: #fffaf0;
  color: #4f6257;
  font-size: 25rpx;
  font-weight: 700;
}

.category-pill.active {
  background: #18211d;
  color: #fffaf0;
}

.selected {
  margin-top: 26rpx;
  overflow: hidden;
  border-radius: 20rpx;
}

.selected-image {
  width: 100%;
  height: 440rpx;
  display: block;
}

.selected-body,
.cart,
.form {
  padding: 28rpx;
}

.selected-name {
  margin-top: 20rpx;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 44rpx;
  font-weight: 700;
}

.selected-meta {
  margin-top: 10rpx;
  color: #657169;
  font-size: 24rpx;
}

.selected-desc {
  margin: 18rpx 0 22rpx;
  color: #354038;
  font-size: 27rpx;
  line-height: 1.68;
}

.selected-proof {
  margin-bottom: 26rpx;
}

.product-list {
  margin-top: 24rpx;
}

.product-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  align-items: center;
  padding: 16rpx;
  margin-top: 16rpx;
}

.product-row.current {
  border-color: rgba(159, 70, 53, 0.36);
}

.product-thumb {
  width: 112rpx;
  height: 112rpx;
  border-radius: 10rpx;
}

.product-info {
  min-width: 0;
  flex: 1 1 360rpx;
}

.product-name {
  min-width: 0;
  overflow: hidden;
  font-size: 27rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-price {
  color: #9f4635;
  font-size: 27rpx;
  font-weight: 800;
}

.product-note {
  margin-top: 10rpx;
  color: #657169;
  font-size: 23rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.add-button {
  display: flex;
  width: 148rpx;
  min-height: 60rpx;
  align-items: center;
  justify-content: center;
  padding: 0;
  border-radius: 10rpx;
  background: #4f6257;
  color: #fffaf0;
  font-size: 23rpx;
  font-weight: 700;
}

.cart-title {
  margin-top: 6rpx;
  font-size: 34rpx;
  font-weight: 800;
}

.cart-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 22rpx 0;
  border-top: 1rpx solid rgba(24, 33, 29, 0.1);
}

.cart-name {
  font-weight: 800;
}

.counter {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.counter button {
  display: flex;
  width: 56rpx;
  height: 56rpx;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  background: #f1eee5;
  color: #18211d;
  font-size: 30rpx;
}

.counter text {
  min-width: 36rpx;
  text-align: center;
  font-weight: 800;
}

.cart-total {
  display: flex;
  justify-content: space-between;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(24, 33, 29, 0.16);
  color: #9f4635;
  font-size: 34rpx;
  font-weight: 900;
}

.picker-line {
  display: flex;
  height: 84rpx;
  align-items: center;
  padding: 0 24rpx;
  border: 1rpx solid rgba(24, 33, 29, 0.14);
  border-radius: 8rpx;
  background: #fffaf0;
  color: #18211d;
}

.submit {
  width: 100%;
  margin-top: 28rpx;
}
